# Local-only env for the ingest script (scripts/ingest.ts).
# Copy to .env and fill in. .env is gitignored.

# Your Cloudflare account ID (Dashboard → Workers & Pages → Account ID).
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token scoped to:
#   - Workers AI: Read
#   - Vectorize:  Edit
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Optional — defaults match wrangler.jsonc. Override only if you renamed things.
# VECTORIZE_INDEX=cloudflare-rag-chatbot
# EMBED_MODEL=@cf/baai/bge-large-en-v1.5
# EMBED_DIM=1024
